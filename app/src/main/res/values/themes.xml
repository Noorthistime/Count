<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Test_Expense_Tracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/nothing_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/nothing_red</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background/Surface colors -->
        <item name="android:windowBackground">@color/black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/nothing_grey_dark</item>
        <item name="colorOnSurfaceVariant">@color/white</item>
        <item name="colorOutline">@color/nothing_grey_medium</item>

        <!-- Status and Navigation bar -->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Typography: Unifying to the Nothing-inspired clean font -->
        <item name="android:fontFamily">@font/normal_font</item>
        <item name="fontFamily">@font/normal_font</item>
    </style>

    <!-- Custom Dialog Theme to inherit the same font -->
    <style name="Theme.Test_Expense_Tracker.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:fontFamily">@font/normal_font</item>
        <item name="fontFamily">@font/normal_font</item>
        <item name="android:windowBackground">@color/nothing_grey_dark</item>
    </style>

    <!-- Theme Variants -->
    <style name="Theme.Test_Expense_Tracker.Red" parent="Theme.Test_Expense_Tracker">
        <item name="colorPrimary">@color/theme_nothing_red</item>
        <item name="colorSecondary">@color/theme_nothing_red</item>
    </style>

    <style name="Theme.Test_Expense_Tracker.Blue" parent="Theme.Test_Expense_Tracker">
        <item name="colorPrimary">@color/theme_ethereal_blue</item>
        <item name="colorSecondary">@color/theme_ethereal_blue</item>
    </style>

    <style name="Theme.Test_Expense_Tracker.Green" parent="Theme.Test_Expense_Tracker">
        <item name="colorPrimary">@color/theme_contrast_green</item>
        <item name="colorSecondary">@color/theme_contrast_green</item>
    </style>

    <style name="Theme.Test_Expense_Tracker.Grey" parent="Theme.Test_Expense_Tracker">
        <item name="colorPrimary">@color/theme_balanced_grey</item>
        <item name="colorSecondary">@color/theme_balanced_grey</item>
    </style>
</resources>