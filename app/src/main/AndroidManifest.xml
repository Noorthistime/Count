<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Test_Expense_Tracker">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Test_Expense_Tracker"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".SummaryActivity"
            android:exported="false"
            android:theme="@style/Theme.Test_Expense_Tracker" />
        <activity
            android:name=".GiveTakeActivity"
            android:exported="false"
            android:theme="@style/Theme.Test_Expense_Tracker" />
        <activity
            android:name=".SyncActivity"
            android:exported="false"
            android:theme="@style/Theme.Test_Expense_Tracker" />
        <activity
            android:name=".QuickAddActivity"
            android:exported="false"
            android:theme="@style/Theme.Test_Expense_Tracker.Dialog"
            android:windowSoftInputMode="adjustResize"
            android:taskAffinity=""
            android:excludeFromRecents="true" />
        <activity
            android:name=".DailyBreakdownActivity"
            android:exported="false"
            android:theme="@style/Theme.Test_Expense_Tracker" />

        <!-- Give/Take Widget -->
        <receiver android:name=".GiveTakeWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/give_take_widget_info" />
        </receiver>

        <!-- Quick Add Expense Widget -->
        <receiver android:name=".AddExpenseWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/add_expense_widget_info" />
        </receiver>

    </application>

</manifest>